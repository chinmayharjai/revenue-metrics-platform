# Hand-written warehouse SQL, run in a worksheet or from the DAG — not a dbt model.
# Same convention as snowflake_setup/ and sql_showcase/: uppercase keywords,
# lowercase columns, which is what a Snowflake worksheet and its result grid look
# like.
#
# LT01/LT02/CP02 excluded for the same reasons documented in
# snowflake_setup/.sqlfluff: indented option blocks under CREATE ... WITH read
# better than sqlfluff's flattening, and these files deliberately mix uppercase
# object names with lowercase column names.
#
# LT05 (line length) matters here more than elsewhere: the prompt is a single
# string literal and breaking it to satisfy a line-length rule would insert
# whitespace into the text the model actually receives. The prompt is the
# behaviour; it is not free to reformat.

[sqlfluff]
dialect = snowflake
max_line_length = 120
exclude_rules = RF04, ST06, AM04, RF02, RF01, CV02, ST05, LT05, LT09, LT12, RF03, AL05, ST03, CP03, AL03, AM06, LT11, LT01, LT02, CP02, RF05

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.identifiers]
extended_capitalisation_policy = upper

[sqlfluff:rules:capitalisation.functions]
extended_capitalisation_policy = upper

[sqlfluff:rules:capitalisation.literals]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.types]
extended_capitalisation_policy = upper
